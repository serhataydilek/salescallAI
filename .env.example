# Backend
# Copy this file to backend/.env for local backend settings.
# Do not commit real .env files.
#
# SQLite is used by default if DATABASE_URL is not set.
# DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/salesmirror
WHISPER_MODEL_SIZE=base
# true = use mock transcription; false = use local faster-whisper
USE_MOCK_TRANSCRIPTION=true

# true = use mock analysis; false = use local Ollama
# Install Ollama and pull OLLAMA_MODEL before setting USE_MOCK_LLM=false.
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:7b
USE_MOCK_LLM=true

# Frontend
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
